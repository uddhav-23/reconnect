rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userExists() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserRole() {
      return userExists()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isSuperAdmin() {
      return request.auth != null && userExists() && getUserRole() == 'superadmin';
    }

    function isSubAdmin() {
      return request.auth != null && userExists() && getUserRole() == 'subadmin';
    }

    function isAdmin() {
      return isSuperAdmin() || isSubAdmin();
    }

    function isMessageParticipant() {
      return request.auth != null
        && (resource.data.senderId == request.auth.uid
            || resource.data.receiverId == request.auth.uid);
    }

    function isMentorshipParticipant(mentorshipId) {
      let m = get(/databases/$(database)/documents/mentorships/$(mentorshipId)).data;
      return request.auth != null
        && (m.mentorId == request.auth.uid || m.menteeId == request.auth.uid);
    }

    /** Mentorship thread: only after mentor accepts (or completed). */
    function mentorshipChatAllowed(mentorshipId) {
      let m = get(/databases/$(database)/documents/mentorships/$(mentorshipId)).data;
      return request.auth != null
        && (m.mentorId == request.auth.uid || m.menteeId == request.auth.uid)
        && (m.status == 'accepted' || m.status == 'completed');
    }

    function isGroupMember(groupId) {
      let g = get(/databases/$(database)/documents/groups/$(groupId)).data;
      return request.auth != null && request.auth.uid in g.members;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /colleges/{collegeId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /blogs/{blogId} {
      allow read: if resource.data.status != 'draft'
        || (request.auth != null
            && (resource.data.authorId == request.auth.uid || isAdmin()));
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if request.auth != null
        && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /achievements/{achievementId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /connections/{connectionId} {
      allow read: if request.auth != null
        && (resource.data.requesterId == request.auth.uid
            || resource.data.receiverId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.requesterId == request.auth.uid;
      allow update, delete: if request.auth != null
        && (resource.data.receiverId == request.auth.uid
            || resource.data.requesterId == request.auth.uid);
    }

    match /messages/{messageId} {
      allow read: if request.auth != null && isMessageParticipant();
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid;
      allow update: if request.auth != null && isMessageParticipant();
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && (
        isAdmin()
        || (request.resource.data.userId == request.auth.uid
            && request.resource.data.actorId == request.auth.uid)
        || (request.resource.data.type == 'message'
            && request.resource.data.keys().hasAll(['userId','messageId','actorId'])
            && exists(/databases/$(database)/documents/messages/$(request.resource.data.messageId))
            && get(/databases/$(database)/documents/messages/$(request.resource.data.messageId)).data.senderId == request.resource.data.actorId
            && get(/databases/$(database)/documents/messages/$(request.resource.data.messageId)).data.receiverId == request.resource.data.userId
            && request.resource.data.actorId == request.auth.uid)
        || (request.resource.data.type == 'comment'
            && request.resource.data.keys().hasAll(['userId','actorId'])
            && request.resource.data.actorId == request.auth.uid)
        || (request.resource.data.type == 'mentorship'
            && request.resource.data.keys().hasAll(['userId','actorId','mentorshipId'])
            && exists(/databases/$(database)/documents/mentorships/$(request.resource.data.mentorshipId))
            && (
              (
                get(/databases/$(database)/documents/mentorships/$(request.resource.data.mentorshipId)).data.mentorId == request.resource.data.userId
                && get(/databases/$(database)/documents/mentorships/$(request.resource.data.mentorshipId)).data.menteeId == request.auth.uid
                && request.resource.data.actorId == request.auth.uid
              )
              || (
                get(/databases/$(database)/documents/mentorships/$(request.resource.data.mentorshipId)).data.menteeId == request.resource.data.userId
                && get(/databases/$(database)/documents/mentorships/$(request.resource.data.mentorshipId)).data.mentorId == request.auth.uid
                && request.resource.data.actorId == request.auth.uid
              )
            ))
        || (request.resource.data.type == 'job_application'
            && request.resource.data.keys().hasAll(['userId','actorId','jobId'])
            && request.resource.data.actorId == request.auth.uid
            && exists(/databases/$(database)/documents/jobs/$(request.resource.data.jobId))
            && get(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)).data.postedBy == request.auth.uid)
      );
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    match /events/{eventId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow create: if request.auth != null
        && (getUserRole() == 'alumni' || isAdmin());
      allow update: if request.auth != null
        && (resource.data.postedBy == request.auth.uid || isAdmin());
      allow delete: if request.auth != null
        && (resource.data.postedBy == request.auth.uid || isAdmin());
    }

    match /mentorships/{mentorshipId} {
      allow read: if request.auth != null
        && (resource.data.mentorId == request.auth.uid
            || resource.data.menteeId == request.auth.uid
            || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.menteeId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.mentorId == request.auth.uid
            || resource.data.menteeId == request.auth.uid
            || isAdmin());
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if mentorshipChatAllowed(mentorshipId);
        allow create: if mentorshipChatAllowed(mentorshipId)
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /groups/{groupId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (request.auth.uid in resource.data.adminIds || isAdmin());
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if request.auth != null && isGroupMember(groupId);
        allow create: if request.auth != null
          && isGroupMember(groupId)
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if request.auth != null
        && request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }
  }
}
